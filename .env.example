# =============================================================================
# AI-Powered Restaurant Recommendation System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# NEVER commit .env to version control.
# =============================================================================

# --- Groq LLM Provider ---
# Required: Get your API key from https://console.groq.com
GROQ_API_KEY=

# Optional: Override default models
GROQ_MODEL_INTENT=llama-3.1-8b-instant
GROQ_MODEL_RANK=llama-3.3-70b-versatile

# Optional: Request timeout in seconds (default: 30)
GROQ_TIMEOUT_SECONDS=30

# --- Data ---
# Path to the preprocessed restaurant dataset (JSON or CSV).
# Generate from Hugging Face Zomato data (one-time or refresh):
#   cd src && python -m app.data.ingest
# Source: https://huggingface.co/datasets/ManikaSaini/zomato-restaurant-recommendation
DATA_PATH=data/restaurants.json

# --- Defaults ---
# Fallback city when user query doesn't mention a location
DEFAULT_CITY=Bengaluru

# Maximum candidates kept after deterministic retrieval (default: 50)
MAX_CANDIDATES=50

# How many pre-ranked candidates are actually sent to the LLM ranker.
# Keep below MAX_CANDIDATES to stay within the provider's tokens-per-minute
# limit; the rest are still used for deterministic backfill (default: 20)
LLM_RANK_CANDIDATES=20

# Default number of recommendations returned (default: 5)
DEFAULT_TOP_N=5

# --- Timezone ---
# Used for open_now logic (IANA timezone name)
TIMEZONE=Asia/Kolkata

# --- Phase 9: Stretch features ---
# Response caching (TTL + LRU)
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=256
# Dependency-free semantic pre-rank (TF-IDF cosine). Weight blends semantic
# similarity vs rating when reordering the candidate shortlist (0.0–1.0).
SEMANTIC_ENABLED=true
SEMANTIC_WEIGHT=0.35
# Conversational sessions (POST /recommend/chat)
SESSION_TTL_SECONDS=1800
SESSION_MAX_ENTRIES=512
# Personalization profiles (opt-in via user_id on requests)
PERSONALIZATION_ENABLED=true

# --- Server ---
# Port to run the API server on
PORT=8000
